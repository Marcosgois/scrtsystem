# ── Banco de dados ─────────────────────────────────────────────────────────
# Por padrão (sem MONGODB_URI), o TFPSystem sobe um MongoDB local persistente
# com os dados gravados em ./data/mongodb, dentro da própria pasta do app.
#
# Para usar outro banco (Atlas ou servidor próprio), descomente e configure:
# MONGODB_URI=mongodb+srv://usuario:senha@cluster0.xxxxx.mongodb.net/tfpsystem
# MONGODB_URI=mongodb://127.0.0.1:27017/tfpsystem
#
# Porta do MongoDB local (mude se a 27017 já estiver em uso):
# LOCAL_DB_PORT=27017

PORT=3000
